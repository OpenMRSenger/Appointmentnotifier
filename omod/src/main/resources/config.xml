<?xml version="1.0" encoding="UTF-8"?>

<module configVersion="1.2">
	
	<!-- Base Module Properties -->
	<id>${project.parent.artifactId}</id>
	<name>${project.parent.name}</name>
	<version>${project.parent.version}</version>
	<package>org.openmrs.module.appointmentnotifier</package>
	<author>Cleme</author>
	<description>
			${project.parent.description}
	</description>

	<activator>org.openmrs.module.appointmentnotifier.AppointmentNotifierActivator</activator>
	
	<!-- <updateURL>https://modules.openmrs.org/modules/download/@MODULE_ID@/update.rdf</updateURL> -->
	<!-- /Base Module Properties -->
	
	<require_version>${openmrsPlatformVersion}</require_version>

	<require_modules>
		<require_module version="2.30.0">org.openmrs.module.webservices.rest</require_module>
	</require_modules>

	<aware_of_modules>
		<aware_of_module>fhir2</aware_of_module>
		<aware_of_module>org.openmrs.module.appointments</aware_of_module>
		<aware_of_module>appointmentscheduling</aware_of_module>
		<aware_of_module>org.openmrs.module.legacyui</aware_of_module>
	</aware_of_modules>
	
	<!-- Extensions -->
	
	
	<!-- Required Privileges 
	<privilege>
		<name>Form Entry</name>
		<description>Allows user to access Form Entry pages/functions</description>
	</privilege>
	 /Required Privileges -->


	<globalProperty>
		<property>appointmentnotifier.saasEndpoint</property>
		<defaultValue>http://host.docker.internal:8888/api/v1/appointment</defaultValue>
		<description>
			Webhook URL that receives a JSON POST on every appointment CREATED / UPDATED / CANCELLED / DELETED event.
			For Discord testing: paste a Discord webhook URL (https://discord.com/api/webhooks/...).
			  The module will automatically format a rich Discord embed instead of plain JSON.
			For production: set to your Spring API endpoint (e.g. http://host.docker.internal:8888/api/v1/appointment).
			  The module will POST application/json with fields: event, appointmentUuid, patientUuid,
			  patientName, serviceName, status, startDateTime, endDateTime, timestamp.
		</description>
	</globalProperty>
	<globalProperty>
		<property>appointmentnotifier.openmrsBaseUrl</property>
		<defaultValue>http://localhost:8080/openmrs</defaultValue>
		<description>
			Base URL of this OpenMRS instance. Used by the REST resource (/ws/rest/v1/appointmentnotifier)
			to fetch appointment lists. In Docker deployments keep this as http://localhost:8080/openmrs.
		</description>
	</globalProperty>
	<globalProperty>
		<property>appointmentnotifier.fhirUsername</property>
		<defaultValue>admin</defaultValue>
		<description>
			OpenMRS username used by the REST resource to authenticate internal API calls.
		</description>
	</globalProperty>
	<globalProperty>
		<property>appointmentnotifier.fhirPassword</property>
		<defaultValue>Admin123</defaultValue>
		<description>
			Password for appointmentnotifier.fhirUsername.
		</description>
	</globalProperty>
	<globalProperty>
		<property>appointmentnotifier.enabled</property>
		<defaultValue>true</defaultValue>
		<description>
			Set to false to disable all webhook notifications without uninstalling the module.
		</description>
	</globalProperty>
	<globalProperty>
		<property>appointmentnotifier.messagingProvider</property>
		<defaultValue>Generic</defaultValue>
		<description>
			Messaging provider identifier sent in the X-Messaging-Provider request header.
			Examples: SwiftSend, Vonage, Twilio, Generic.
			The SaaS backend uses this header to select the correct SMS adapter.
			Has no effect when testing with a Discord webhook.
		</description>
	</globalProperty>
	<globalProperty>
		<property>appointmentnotifier.maxRetries</property>
		<defaultValue>5</defaultValue>
		<description>
			Maximum number of dispatch attempts before an outbox entry is permanently skipped.
			To manually requeue a permanently-failed entry, reset its status to PENDING in the
			saas_integration_queue table and its retry_count to 0.
		</description>
	</globalProperty>
	
